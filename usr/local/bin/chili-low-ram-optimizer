MostraErro() { echo "erro: ${red}$1${reset} => comando: ${cyan}'$2'${reset} => result=${yellow}$3${reset}"; }
# Sugestão de alteração no seu trap atual:
trap 'MostraErro "$APP[$FUNCNAME][$LINENO]" "$BASH_COMMAND" "$?"; if readconf "Erro detectado. Deseja tentar restaurar o backup anterior?"; then sh_rollback; fi; exit 1' ERR
trap 'MostraErro "$APP[$FUNCNAME][$LINENO]" "$BASH_COMMAND" "$?"; exit 1' ERR

sh_check_terminal() { [ ! -t 1 ] && use_color=false; }

set_varcolors() {
	sh_check_terminal
	# does the terminal support true-color?
	if [[ -n "$(command -v "tput")" ]]; then
		#tput setaf 127 | cat -v  #capturar saida
		: "${RED=$(tput bold)$(tput setaf 196)}"
		: "${GREEN=$(tput bold)$(tput setaf 2)}"
		: "${YELLOW=$(tput bold)$(tput setaf 3)}"
		: "${BLUE=$(tput setaf 4)}"
		: "${PURPLE=$(tput setaf 125)}"
		: "${CYAN=$(tput setaf 6)}"
		: "${NC=$(tput sgr0)}"
		: "${RESET=$(tput sgr0)}"
		: "${BOLD=$(tput bold)}"
		: "${black=$(tput bold)$(tput setaf 0)}"
		: "${reverse=$(tput rev)}"
		: "${branca=${black}$(tput setab 7)}"

		: "${reset=$(tput sgr0)}"
		: "${rst=$(tput sgr0)}"
		: "${bold=$(tput bold)}"
		: "${underline=$(tput smul)}"
		: "${nounderline=$(tput rmul)}"
		: "${reverse=$(tput rev)}"

		: "${black=$(tput bold)$(tput setaf 0)}"
		: "${red=$(tput bold)$(tput setaf 196)}"
		: "${green=$(tput bold)$(tput setaf 2)}"
		: "${yellow=$(tput bold)$(tput setaf 3)}"
		: "${blue=$(tput setaf 27)}"
		: "${pink=$(tput setaf 5)}"
		: "${magenta=$(tput setaf 5)}"
		: "${cyan=$(tput setaf 6)}"
		: "${white=$(tput setaf 7)}"
		: "${gray=$(tput setaf 8)}"
		: "${light_red=$(tput setaf 9)}"
		: "${light_green=$(tput setaf 10)}"
		: "${light_yellow=$(tput setaf 11)}"
		: "${light_blue=$(tput setaf 12)}"
		: "${light_magenta=$(tput setaf 13)}"
		: "${light_cyan=$(tput setaf 14)}"
		: "${light_white=$(tput setaf 15)}"
		: "${orange=$(tput setaf 202)}"
		: "${purple=$(tput setaf 125)}"
		: "${violet=$(tput setaf 61)}"

		# Definir cores de fundo
		: "${preto=$(tput setab 0)}"
		: "${vermelho=$(tput setab 196)}"
		: "${verde=$(tput setab 2)}"
		: "${amarelo=$(tput setab 3)}"
		: "${azul=$(tput setab 20)}"
		: "${roxo=$(tput setab 5)}"
		: "${ciano=$(tput setab 6)}"
		: "${branca="${black}$(tput setab 7)"}"
		: "${cinza=$(tput setab 8)}"
		: "${laranja=$(tput setab 202)}"
		: "${roxa=$(tput setab 125)}"
		: "${violeta=$(tput setab 61)}"

		: "${COL_NC='\e[0m'}" # No Color
		: "${COL_LIGHT_GREEN='\e[1;32m'}"
		: "${COL_LIGHT_RED='\e[1;31m'}"
		: "${DONE="${COL_LIGHT_GREEN} done!${COL_NC}"}"
		: "${OVER="\\r\\033[K"}"
		: "${DOTPREFIX="  ${black}::${reset} "}"
		: "${clrkey=${light_white}}"
		: "${TICK="${clrkey}[${green} ✓ ${clrkey}]${rst}"}"
		: "${CROSS="${clrkey}[${red} ✗ ${clrkey}]${rst}"}"
		: "${MID="${clrkey}[${red}✗✗${green}✓${clrkey}]${rst}"}"
		: "${WARN="${clrkey}[${yellow}⚠  ${clrkey}]${yellow}"}"
		: "${INFO="${clrkey}[${black}➡  ${clrkey}]${rst}"}"
	else
		unset_varcolors
	fi
}

unset_varcolors() {
	unset RED GREEN YELLOW BLUE PURPLE CYAN NC RESET BOLD
	unset reset rst bold underline nounderline reverse
	unset black red green yellow blue magenta cyan white gray orange purple violet
	unset light_red light_green light_yellow light_blue light_magenta light_cyan light_white
	unset preto vermelho verde amarelo azul roxo ciano branca cinza laranja roxa violeta
	TICK="${white}[${verde}✓${rst}${white}]${rst}"
	CROSS="${white}[${roxa}✗${rst}${white}]${rst}"
	INFO="${white}[${cinza}i${rst}${white}]${rst}"
}

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	msg "This script must be run as root. Elevating privileges..."
	ccabec+='root [elevated]'
	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi
	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

replicate() {
	local char="${1:-#}"
	local nsize="${2:-$(tput cols)}"
	# Gera linha com substituição direta sem forks extras
	printf -v _line "%*s" "$nsize" && printf '%b\n' "${blue}${_line// /$char}${reset}"
}

readconf() {
	local msg="$1"
	local color="${2:-${yellow}}"

	echo -n -e "$color"
	if [[ $LC_DEFAULT -eq 0 ]]; then
		read -r -p "$msg [N/s] :"
	else
		read -r -p "$msg [N/y] :"
	fi
	echo -n -e "$reset"
	case "${REPLY^}" in
	[SY]) return 0 ;;
	"") return 1 ;;
	*) return 1 ;;
	esac
}

debug() {
	whiptail \
		--fb \
		--clear \
		--backtitle "[debug]$0" \
		--title "[debug]$0" \
		--yesno "${*}\n" 0 40

	local result="$?"
	((result)) && exit "$result"
	return "$result"
}

run_cmd() {
	local cmd="$*"

	if [[ $DRYRUN -eq 1 ]]; then
		msg "${cyan}[DRY-RUN]${rst} ${cmd}"
	else
		echo -e "  [⚙  ] ${cyan}${cmd}${rst}"
		# Executa o comando de forma segura
		# Redireciona stderr para /dev/null apenas para mkdir -p e ummount -R
		if [[ "$cmd" == *"mkdir -p"* ]] || [[ "$cmd" == *"umount -R"* ]]; then
			eval "$cmd" &>/dev/null || true
		else
			eval "$cmd" &>/dev/null || log_warn_tab "Falha ao executar: $cmd"
		fi
	fi
}

sh_copyright() {
	cat <<-EOF-COPY
		${bold}${cyan}${0##*/} v${_VERSION_}${rst}
		${bold}${cyan}${APPDESC}${rst}
		${bold}${orange}Copyright (c) 2019-2026, ${reset}ChiliLinux Development Team <https://chililinux.com> <https://github.com/chililinux>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}VoidBR Development Team <https://voidbr.org> <https://github.com/voidlinuxbr>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}Vilmar Catafesta <vcatafesta@gmail.com>${black}
	EOF-COPY
}

sh_version() {
	cat <<-EOF-VERSION
		  $(sh_copyright)

		        $(gettext "Este é um software livre: você é livre para alterá-lo e redistribuí-lo.")
		        $(gettext "O $APP é disponibilizado para você sob a ${yellow}Licença MIT${black}, e")
		        $(gettext "inclui software de código aberto sob uma variedade de outras licenças.")
		        $(gettext "Você pode ler instruções sobre como baixar e criar para você mesmo")
		        $(gettext "o código fonte específico usado para criar esta cópia.")
		        ${red}$(gettext "Este programa vem com absolutamente NENHUMA garantia.")${reset}
	EOF-VERSION
}

msg() { echo -e "${INFO} ${*}${reset}"; }
log_ok() { echo -e "${TICK} ${*}${reset}"; }
log_err() { echo -e "${CROSS} ${*}${reset}"; }
log_mid() { echo -e "${MID} ${*}${reset}"; }
log_warn() { echo -e "${WARN} ${*}${reset}"; }
warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
msg_warn() { echo -e "${WARN} ${*}${reset}"; }
warn() { echo -e "${WARN} ${*}${reset}"; }
msg_tab() { echo -e "  ${INFO} ${*}${reset}"; }
log_ok_tab() { echo -e "  ${TICK} ${*}${reset}"; }
log_err_tab() { echo -e "  ${CROSS} ${*}${reset}"; }
log_mid_tab() { echo -e "  ${MID} ${*}${reset}"; }
log_warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
die() {
	echo -e "${CROSS} ${red}${*}${reset}"
	exit 1
}

detect_distro() {
	local id=""
	if [[ -r /etc/os-release ]]; then
		# Lê ID=void|arch|debian|... exatamente como a distro declara
		id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
	elif [[ -r /usr/lib/os-release ]]; then
		id=$(grep -E '^ID=' /usr/lib/os-release | cut -d= -f2 | tr -d '"')
	else
		echo "unknown"
		return
	fi
	echo "$id"
}

detect_is_live() {
  local rootfs="$(findmnt -n -o FSTYPE /)"

  case "$rootfs" in
    squashfs|overlay) return 0;;
    *) return 1;;
  esac
}

sh_checkDependencies() {
	local aBlock_files=()
	local d
	local pkg
	local errorFound=false
	declare -a missing
	local DISTRO
	local cmsgNot
	local cmsgPkg
	DISTRO="$(detect_distro)"
	cmsgNot="$(gettext "Não foi possível encontrar o comando")"
	cmsgPkg="$(gettext "instalar pacote")"

	for d in "${!PACKAGEDEP[@]}"; do
		if ! command -v "$d" &>/dev/null; then
			pkg="${PACKAGEDEP[$d]}"
			log_err "${red}Error${rst}: ${cmsgNot} $(printf "${cyan}%-15s${rst}\n" "$d") -> ${cmsgPkg} ${cyan}${pkg}${rst}"
			missing+=("${pkg}")
			errorFound=true
		else
			#log_msg "Check: ${cyan}$d"
			:
		fi
	done

	if $errorFound; then
		replicate '='
		echo "${yellow}             $(gettext "IMPOSSÍVEL CONTINUAR")"
		echo "${black}$(gettext "Este script precisa dos comandos listados acima")"
		echo "${black}$(gettext "Instale-os e/ou verifique se eles estão em seu") ${red}\$PATH${reset}"
		replicate '='

		local cmd="${DISTRO_MGR[$DISTRO]}"
		#local pkgs="${DISTRO_PKGS[$DISTRO]}"
		local pkgs="${missing[@]}"

		msg_info "Distro detectada: ${cyan}$DISTRO${rst}"
		if readconf "$(gettext "Instalar dependências base agora?")"; then
			echo -e "${blue}::${rst} $(gettext "Preparando ambiente para") ${green}${DISTRO}${reset}..."
			# Execução dinâmica: $cmd (gerenciador) + $pkgs (lista de pacotes)
			if ! $cmd "$pkgs"; then
				echo
				echo -e "${red}$(gettext "Erro Crítico:")${rst} $(gettext "A instalação dos pacotes básicos falhou.")"
				exit 1
			fi
			echo
			echo -e "${green}$(gettext "Sucesso:")${reset} $(gettext "Dependências instaladas.")"
		fi
	fi
}

# configure ambiente
set_varcolors
sh_checkroot "$@"

##########################################################################################################

#warn() { printf "${yellow}==> AVISO:${reset} %s\n" "$1"; }
err() { printf "${red}==> ERRO:${reset} %s\n" "$1"; }
changed=false

detect_init() {
	local init_system=$(ps -p 1 -o comm=)
	case "$init_system" in
	systemd) init="systemd" ;;
	runit) init="runit" ;;
	*) init="unknown" ;;
	esac
}

check_root() {
	if [[ $EUID -ne 0 ]]; then
		err "Execute como root."
		exit 1
	fi
}

sh_rename_service_on_runit() {
	# 2. Limpeza específica para runit
	if [[ "$init" == "runit" ]]; then
		if [[ -e "${sysctl_conf_runit}" ]]; then
			run_cmd mv -f "${sysctl_conf_runit}" "${sysctl_conf}"
			changed=true
		fi
	fi
}

cleanup_legacy() {
	msg "Limpando vestígios de versões anteriores..."

	for f in "${legacy_files[@]}"; do
		if [ -f "$f" ]; then
			msg_warn "Removendo arquivo legado: $(basename "$f")"
			run_cmd rm -f "$f"
			changed=true
		fi
	done

	# 2. Limpeza específica para runit
	sh_rename_service_on_runit

	# 3. Limpeza específica para Systemd
	if [[ "$init" == "systemd" ]]; then
		local services=("chili-thp" "chili-bfq" "chili-zram")
		for svc in "${services[@]}"; do
			if [ -f "/etc/systemd/system/${svc}.service" ]; then
				msg_warn "Desativando serviço antigo: $svc"
				run_cmd systemctl disable "$svc"
				run_cmd rm -f "/etc/systemd/system/${svc}.service"
				changed=true
			fi
		done

		if $changed; then
			run_cmd systemctl daemon-reload
		fi
	fi
}

detect_ram() {
	# Declara explicitamente como global para o interpretador
	declare -g ram_gb
	ram_gb=$(awk '/MemTotal/ {printf "%.0f", $2/1024/1024}' /proc/meminfo)
}

detect_fs() {
	# findmnt busca diretamente no /proc/self/mountinfo
	# -n remove o cabeçalho, -o FSTYPE traz apenas o tipo do FS
	root_fs=$(findmnt -n -o FSTYPE /)

	# Fallback caso o findmnt não esteja disponível (raro em distros modernas)
	if [[ -z "$root_fs" ]]; then
		root_fs=$(awk '$2 == "/" {print $3}' /proc/mounts)
	fi
}

supports_hibernation() {
	grep -q "resume=" /proc/cmdline
}

remove_zram() {
	if grep -q "^zram" /proc/modules; then
		msg "Removendo zram..."
		if command -v zramctl >/dev/null; then
			for dev in $(zramctl -n -o NAME 2>/dev/null); do
				run_cmd swapoff "$dev"
			done
		fi
		run_cmd modprobe -r zram
		changed=true
	fi

	run_cmd mkdir -p /etc/modprobe.d
	if ! grep -q "^blacklist zram" /etc/modprobe.d/disable-zram.conf 2>/dev/null; then
		echo "blacklist zram" >/etc/modprobe.d/disable-zram.conf
		changed=true
	fi
}

check_disk_space() {
	local required_mb=$((swap_gb * 1024))

	# espaço disponível em MB
	local avail_mb
	avail_mb=$(df -Pm / | awk 'NR==2 {print $4}')

	if ((avail_mb < required_mb)); then
		msg "Erro: espaço insuficiente em disco!"
		msg "Necessário: ${swap_gb}G | Disponível: $((avail_mb / 1024))G"
		return 1
	fi
}

configure_swapfile() {
	local needs_recreate=false
	local desired_size

  if detect_is_live; then
    swap_gb=1
  fi
  desired_size=$((swap_gb * 1024 * 1024 * 1024))

	msg "Verificando integridade do /swapfile..."

	if [[ -f /swapfile ]]; then
		local current_size=$(stat -c%s /swapfile)
		if [ "$current_size" -ne "$desired_size" ]; then
			warn "Tamanho atual diverge do recomendado (${swap_gb}G)."
			needs_recreate=true
		else
			msg_tab "${green}Swapfile já está no tamanho correto.${reset}"
		fi
	else
		needs_recreate=true
	fi

	if $needs_recreate; then
		# 1. Verifica espaço em disco antes de começar
		local avail_mb=$(df -Pm / | awk 'NR==2 {print $4}')
		if ((avail_mb < (swap_gb * 1024))); then
			err "Espaço insuficiente! Necessário: ${swap_gb}G | Disponível: $((avail_mb / 1024))G"
			return 1
		fi

		# 2. Desativa e remove o antigo se existir
		if [ -f /swapfile ]; then
			run_cmd swapoff /swapfile
			run_cmd rm -f /swapfile
		fi

		msg "Criando swapfile de ${swap_gb}G no $root_fs..."
		case "$root_fs" in
		btrfs)
			if command -v btrfs >/dev/null && btrfs filesystem --help 2>&1 | grep -q "mkswapfile"; then
				run_cmd btrfs filesystem mkswapfile --size ${swap_gb}g /swapfile
			else
				run_cmd truncate -s 0 /swapfile
				run_cmd chattr +C /swapfile
				run_cmd btrfs property set /swapfile compression none
				run_cmd fallocate -l ${swap_gb}G /swapfile || run_cmd dd if=/dev/zero of=/swapfile bs=1G count=${swap_gb} status=progress oflag=direct
			fi
			;;
		*)
			run_cmd fallocate -l ${swap_gb}G /swapfile || run_cmd dd if=/dev/zero of=/swapfile bs=1G count=${swap_gb} status=progress oflag=direct
			;;
		esac

		run_cmd chmod 600 /swapfile
		run_cmd mkswap /swapfile
		changed=true
	fi

	# 3. Garante a entrada no fstab sem duplicar
	if ! grep -qE '^[[:space:]]*/swapfile[[:space:]]' /etc/fstab; then
		echo "/swapfile none swap defaults,pri=20 0 0" >>/etc/fstab
		changed=true
	fi
	return 0
}

configure_sysctl() {
	local cfile
	cfile="${sysctl_conf}"

	msg "Configurando parâmetros de memória..."
	run_cmd mkdir -p /etc/sysctl.d/

	if [ ! -f "${cfile}" ]; then
		cat <<EOF >"${cfile}"
vm.swappiness=180
vm.vfs_cache_pressure=200
vm.page-cluster=0
vm.dirty_background_ratio=3
vm.dirty_ratio=10
vm.dirty_expire_centisecs=3000
vm.dirty_writeback_centisecs=500
EOF
		run_cmd sysctl --system
		changed=true
	else
		msg_tab "${green}Sysctl já configurado.${rst}"
	fi
}

configure_zswap() {
	local cfile
	cfile="/etc/default/grub"
	msg "Configurando zswap..."

	[ -f "${cfile}" ] || {
		warn "Arquivo ${cfile} não encontrado."
		return
	}

	# garante linha
	grep -q '^GRUB_CMDLINE_LINUX=' "${cfile}" ||
		echo 'GRUB_CMDLINE_LINUX=""' >>"${cfile}"

	# pega conteúdo atual
	current=$(sed -n 's/^GRUB_CMDLINE_LINUX="\([^"]*\)"/\1/p' "${cfile}")

	# remove params antigos
	current="${current//zswap.enabled=*/}"
	current="${current//zswap.max_pool_percent=*/}"

	# normaliza espaços
	current="$(echo "$current" | xargs)"

	# adiciona correto
	new="$current zswap.enabled=1 zswap.max_pool_percent=25"
	new="$(echo "$new" | xargs)"

	# só altera se mudou
	if ! grep -q "GRUB_CMDLINE_LINUX=\"$new\"" "${cfile}"; then
		sed -i "s|^GRUB_CMDLINE_LINUX=.*|GRUB_CMDLINE_LINUX=\"$new\"|" "${cfile}"
		if command -v update-grub >/dev/null; then
			run_cmd update-grub
		else
			run_cmd grub-mkconfig -o /boot/grub/grub.cfg
		fi
		changed=true
	else
		msg_tab "${green}zswap já configurado.${rst}"
	fi
}

configure_scheduler() {
	local cfile

	if [[ "$init" == "runit" ]]; then
		cfile="${ASERVICES['bfq-runit']}"
		if [[ ! -f "${cfile}" ]]; then
			cat <<EOF >"${cfile}"
#!/bin/sh
for d in /sys/block/*; do
	[ -e "\$d/queue/scheduler" ] && echo "$scheduler" > "\$d/queue/scheduler" 2>/dev/null
done
EOF

			run_cmd chmod +x "${cfile}"
			changed=true
		else
			msg_tab "${green}Scheduler já configurado.${rst}"
		fi
	elif [[ "$init" == "systemd" ]]; then
		cfile="${ASERVICES['bfq-systemd']}"
		if [ ! -f "${cfile}" ]; then
			cat <<EOF >"${cfile}"
[Unit]
Description=Set BFQ IO Scheduler (Chili)
[Service]
Type=oneshot
ExecStart=/bin/sh -c 'for d in /sys/block/sd*; do echo bfq > "\$d/queue/scheduler" 2>/dev/null; done'
RemainAfterExit=yes
[Install]
WantedBy=multi-user.target
EOF
			run_cmd systemctl daemon-reload
			run_cmd systemctl enable chili-bfq
			changed=true
		else
			msg_tab "${green}Scheduler já configurado.${rst}"
		fi
	fi
}

configure_thp() {
	local cfile

	msg "Configurando THP"
	if [[ "$init" == "runit" ]]; then
		cfile="${ASERVICES['thp-runit']}"
		if [ ! -f "${cfile}" ]; then
			cat <<'EOF' >"${cfile}"
#!/bin/sh
echo never > /sys/kernel/mm/transparent_hugepage/enabled
EOF
			run_cmd chmod +x "${cfile}"
			changed=true
		else
			msg_tab "${green}THP já configurado.${rst}"
		fi

	elif [[ "$init" == "systemd" ]]; then
		cfile="${ASERVICES['thp-systemd']}"
		if [ ! -f "${cfile}" ]; then
			cat <<'EOF' >"${cfile}"
[Unit]
Description=Disable Transparent Huge Pages (Chili)
[Service]
Type=oneshot
ExecStart=/bin/sh -c 'echo never > /sys/kernel/mm/transparent_hugepage/enabled'
RemainAfterExit=yes
[Install]
WantedBy=multi-user.target
EOF
			run_cmd systemctl daemon-reload
			run_cmd systemctl enable chili-thp
			changed=true
		else
			msg_tab "${green}THP já configurado.${rst}"
		fi
	fi
}

detect_disk() {
	# Identifica o disco físico (ex: sda, nvme0n1) que contém a partição raiz
	# lsblk -no PKNAME pega o nome do dispositivo pai
	disk=$(lsblk -no PKNAME "$(findmnt -n -o SOURCE /)" 2>/dev/null | tail -n1)

	# Fallback caso o sistema não use nomes de partição padrão
	[[ -z "$disk" ]] && disk=$(lsblk -ndo NAME,TYPE | awk '$2=="disk"{print $1;exit}')

	# Verifica se o disco é rotacional (HDD) ou não (SSD/NVMe)
	is_rotational=$(cat /sys/block/"$disk"/queue/rotational 2>/dev/null)

	if [[ "$is_rotational" == "0" ]]; then
		type="SSD"
		scheduler="mq-deadline"
	else
		type="HDD"
		scheduler="bfq"
	fi
}

enable_swap() {
	if ! swapon --show=NAME | grep -q "^/swapfile$"; then
		run_cmd swapon /swapfile
	fi
}

enable_preload() {
	local cmd="${DISTRO_MGR[$DISTRO]}"
	local pkgs="preload"

	# 1. Instalação (apenas se não existir)
	if ! command -v preload >/dev/null 2>&1; then
		msg "Instalando preload..."
		# Execução dinâmica: $cmd (gerenciador) + $pkgs (lista de pacotes)
		if ! run_cmd $cmd "$pkgs"; then
			warn "A instalação dos pacotes básicos falhou."
			return 1
		fi
		changed=true
	fi

	# 2. Ativação do Serviço
	if [[ "$init" == "systemd" ]]; then
		# Verifica se o serviço NÃO está habilitado
		if ! systemctl is-enabled --quiet preload 2>/dev/null; then
			msg_tab "Habilitando serviço preload (systemd)..."
			run_cmd systemctl daemon-reload
			run_cmd systemctl enable --now preload
			changed=true
		fi
	elif [[ "$init" == "runit" ]]; then
		# No runit, verificamos o link simbólico em /var/service
		if [ ! -L /var/service/preload ]; then
			msg_tab "Ativando serviço preload (runit)..."
			run_cmd ln -sf /etc/sv/preload /var/service/
			changed=true
		fi
	fi
}

disable_preload() {
	if command -v sv >/dev/null 2>&1; then
		msg "Desativando preload (runit)..."
		run_cmd sudo rm -f /var/service/preload
	elif command -v systemctl >/dev/null 2>&1; then
		msg "Desativando preload (systemd)..."
		run_cmd sudo systemctl disable --now preload
	fi
}

ensure_debugfs() {
	if ! mountpoint -q /sys/kernel/debug; then
		msg "Montando debugfs..."
		run_cmd mount -t debugfs none /sys/kernel/debug
	fi
}

sh_check_zswap_lifecycle() {
	msg "Diagnóstico Zswap"

	# 1. Suporte no Kernel
	if detect_zswap_support; then
		msg_tab "Suporte do Kernel: ${green}OK ${cyan}(Kernel compilado com suporte a zswap)${rst}"
	else
		log_warn_tab "Suporte do Kernel: ${red}Ausente!${rst}"
		((errors++))
		return # Se não tem suporte, não adianta checar o resto
	fi

	# 2. Intenção no Boot (Grub/Cmdline)
	if grep -q "zswap.enabled=1" /proc/cmdline; then
		msg_tab "Parâmetro de Boot: ${green}OK ${cyan}(Ativado no Kernel Cmdline)${rst}"
	else
		log_warn_tab "Parâmetro de Boot: ${red}Ausente (Verifique seu GRUB/Bootloader)${rst}"
		((errors++))
	fi

	# 3. Estado do Módulo
	if [[ -f "/sys/module/zswap/parameters/enabled" ]]; then
		local active=$(cat /sys/module/zswap/parameters/enabled)
		if [[ "$active" == "Y" ]]; then
			msg_tab "Zswap ativo      : ${green}Ativo ${cyan}(${active})${rst}"
		else
			log_warn_tab "Zswap ativo : ${yellow}Carregado mas desativado (${active})${rst}"
			((errors++))
		fi
	else
		log_warn_tab "Módulo: ${red}Não carregado no Kernel${rst}"
		((errors++))
	fi
}

detect_zswap_support() {
	if zgrep -q '^CONFIG_ZSWAP=[ym]$' /proc/config.gz 2>/dev/null; then
		return 0
	fi

	if grep -q '^CONFIG_ZSWAP=[ym]$' "/boot/config-$(uname -r)" 2>/dev/null; then
		return 0
	fi

	return 1
}

detect_zswap() {
	zswap_enabled='N'
	# zswap básico
	if [ -d /sys/module/zswap ]; then
		zswap_enabled="$(cat /sys/module/zswap/parameters/enabled)"
	fi
}

disable_zswap() {
	msg "Desativando zswap..."
	run_cmd 'echo 0 > /sys/module/zswap/parameters/enabled'
}

enable_zswap() {
	msg "Ativando zswap..."
	run_cmd 'echo 1 > /sys/module/zswap/parameters/enabled'
}

calculate_swap() {
	msg "Análise de Swap"

	# 1. Detecção de Modo (Hibernação vs Low RAM)
	local mode_label="${cyan}low RAM${reset}"
	local is_hibernation=false
	if grep -q "resume=" /proc/cmdline; then
		is_hibernation=true
		mode_label="${cyan}hibernação${reset}"
	fi

	# 2. Lógica de Cálculo de Swap Ideal
	if $is_hibernation; then
		if ((ram_gb <= 2)); then
			swap_gb=$((ram_gb * 2))
		elif ((ram_gb <= 8)); then
			swap_gb=$((ram_gb + ram_gb / 2))
		else swap_gb=$((ram_gb + 4)); fi
	else
		if ((ram_gb <= 2)); then
			swap_gb=$((ram_gb * 2))
		elif ((ram_gb <= 8)); then
			swap_gb=$ram_gb
		else swap_gb=8; fi
	fi

	# 3. Coleta de dados físicos do arquivo /swapfile
	local current_gb=0
	if [ -f /swapfile ]; then
		current_gb=$(($(stat -c%s /swapfile) / 1024 / 1024 / 1024))
	fi

	# 4. Saída Consolidada de Diagnóstico
	msg_tab "Modo detectado   : $mode_label"
	msg_tab "Swap recomendada : ${cyan}${swap_gb} GB${reset}"

	local color=$cyan
	[[ "$current_gb" -ne "$swap_gb" ]] && color=$yellow
	msg_tab "Arquivo /swapfile: ${color}${current_gb} GB${reset}"

	# 5. Verifica se o /swapfile está ativo
	# Usamos tail -n +2 para pular o cabeçalho de forma compatível
	local active_info=$(swapon --show=NAME,TYPE,SIZE,PRIO | grep "^/swapfile ")

	if [[ -n "$active_info" ]]; then
		msg_tab "Swap ativo       : ${cyan}${active_info}${reset}"
	else
		msg_tab "Swap inativo     : ${red}/swapfile NÃO está em uso/ativo!${reset}"
	fi

	# 6. Monitoramento de redundância (outras swaps ativas)
	# Filtra o /swapfile e o cabeçalho (NAME)
	local other_swaps=$(swapon --show=NAME | tail -n +2 | grep -v "^/swapfile" | xargs)
	if [[ -n "$other_swaps" ]]; then
		msg_tab "Outros devices   : ${yellow}${other_swaps}${reset} (partição detectada)"
	fi
}

sh_summary_swap() {
	replicate '-'
	# vm.swappiness
	swappiness=$(sysctl -n vm.swappiness)

	# zswap / zram
	accept_threshold_percent=$(cat /sys/module/zswap/parameters/accept_threshold_percent 2>/dev/null)
	enabled=$(cat /sys/module/zswap/parameters/enabled 2>/dev/null)
	max_pool_percent=$(cat /sys/module/zswap/parameters/max_pool_percent 2>/dev/null)
	shrinker_enabled=$(cat /sys/module/zswap/parameters/shrinker_enabled 2>/dev/null)
	# pega somente o compressor ativo entre [ ]
	compressor=$(cat /sys/module/zswap/parameters/compressor)

	echo -e "\
[➡  ] vm.swappiness = $swappiness ${yellow}
      Define o quanto o kernel prefere usar swap.
      Valores altos favorecem zram/zswap e ajudam multitarefa. ${rst}
[➡  ] accept_threshold_percent : $accept_threshold_percent ${yellow}
      Percentual de uso de memória para começar a aceitar páginas no zswap. ${rst}
[➡  ] compressor : $compressor ${yellow}
      Algoritmo de compressão usado.
      zstd oferece ótimo equilíbrio entre velocidade e compressão. ${rst}
[➡  ] enabled : $enabled ${yellow}
      Define se o zswap está ativado. ${rst}
[➡  ] max_pool_percent : $max_pool_percent ${yellow}
      Limite máximo de RAM que o zswap pode utilizar. ${rst}
[➡  ] shrinker_enabled : $shrinker_enabled ${yellow}
      Permite ao kernel liberar memória com mais agressividade sob pressão. ${rst}"
}

sh_system_summary() {
  detect_init
  detect_fs
  detect_ram
  detect_disk
  #calculate_swap
  ensure_debugfs
	msg "System Summary"
	msg_tab "Distro detectada: ${cyan}${DISTRO}${rst}"
	msg_tab "Init detectado  : ${cyan}${init}${rst}"
	msg_tab "Filesystem raiz : ${cyan}${root_fs}${rst}"
	msg_tab "Disco detectado : ${cyan}$type ($disk)${rst}"
	msg_tab "RAM detectada   : ${cyan}${ram_gb} GB${rst}"
  msg_tab "Modo do sistema : ${cyan}$(if detect_is_live; then echo Live; else echo Instalado; fi)${rst}"
}

summary() {
	replicate '-'
	echo "${blue}Resumo do sistema${rst}"
	replicate '-'
	sh_system_summary
	calculate_swap
	detect_zswap
  sh_check_zswap_lifecycle

	if [ $zswap_enabled = 'Y' ]; then
		msg_tab "$(sysctl vm.swappiness)"
		for f in /sys/module/zswap/parameters/*; do
			msg_tab "$(printf "%-30s : ${cyan}%s\n" "$(basename "$f")" "$(cat "$f")")"
		done

		# debugfs (stats)
		if mountpoint -q /sys/kernel/debug 2>/dev/null && [ -d /sys/kernel/debug/zswap ]; then
			msg_tab "Dump das métricas do zswap     :" ${cyan}$(cat /sys/kernel/debug/zswap/*)${rst}
		else
			msg_tab "zswap stats     : ${cyan}debugfs não montado${rst}"
		fi
	fi
	#replicate '#'

	if $changed; then
		echo
		warn "${yellow}Alterações efetuadas. Reinicie o sistema!${reset}"
	else
		#echo
		#msg "${green}Nenhuma alteração foi necessária.${rst}"
		:
	fi
}

sh_install() {
	check_root
	detect_init
	detect_fs
  if detect_is_live; then
    err "Sistema em modo Live. As alterações serão perdidas ao reiniciar. Rodando em modo dry-run"
  fi
	sh_create_checkpoint
	cleanup_legacy
	detect_ram
	calculate_swap
	remove_zram
	configure_swapfile
	configure_sysctl
	configure_zswap
	configure_thp
	detect_disk
	configure_scheduler
	enable_swap
	enable_preload
	ensure_debugfs
	enable_zswap
#	summary
  sh_health_check

  if detect_is_live; then
		warn "${yellow}Alterações efetuadas. Reinicie o sistema!${reset}"
    die "Sistema em modo Live. As alterações serão perdidas ao reiniciar."
  fi
}

sh_uninstall() {
	msg "Removendo configurações..."
	detect_init

	# swapfile
	if swapon --show=NAME | grep -q '^/swapfile$'; then
		run_cmd swapoff /swapfile
	fi
	run_cmd rm -f /swapfile
	sed -i '\|/swapfile|d' /etc/fstab

	# sysctl
	run_cmd rm -f "${sysctl_conf}"

	# zram blacklist
	run_cmd rm -f /etc/modprobe.d/disable-zram.conf

	# zswap (GRUB)
	if [ -f /etc/default/grub ]; then
		sed -i '/^GRUB_CMDLINE_LINUX="/{
      s/\<zswap.enabled=[^ "]*\>//g
      s/\<zswap.max_pool_percent=[^ "]*\>//g
      s/  */ /g
      s/=" */="/
      s/ *"$/"/
    }' /etc/default/grub

		if command -v update-grub >/dev/null; then
			run_cmd update-grub
		else
			run_cmd grub-mkconfig -o /boot/grub/grub.cfg
		fi
	fi

	# limpeza por init
	case "$init" in
	runit)
		msg "Removendo configurações (runit)..."
		run_cmd rm -f "${ASERVICES['thp-runit']}"
		run_cmd rm -f "${ASERVICES['bfq-runit']}"
		run_cmd rm -f /etc/runit/core-services/10-zram.sh
		run_cmd rm -f /etc/runit/core-services/10-voidbr-zram.sh
		;;

	systemd)
		msg "Removendo configurações (systemd)..."
		run_cmd systemctl disable chili-thp
		run_cmd systemctl disable chili-bfq
		run_cmd rm -f "${ASERVICES['thp-systemd']}"
		run_cmd rm -f "${ASERVICES['bfq-systemd']}"
		run_cmd systemctl daemon-reload
		;;
	esac
	disable_preload
	disable_zswap
	msg "${green}Remoção concluída.${rst}"
	warn "${yellow}Alterações efetuadas. Reinicie o sistema!${reset}"
}

usage() {
	echo -e "${cyan}Uso:${reset} $APP [opção]"
	echo -e "${cyan}Opções:${reset}"
	echo -e "  ${yellow}-s, --show           ${rst} $(gettext 'mostra resumo do sistema')"
	echo -e "  ${yellow}-ss, --show-extended ${rst} $(gettext 'mostra resumo explicado do sistema')"
	echo -e "  ${green}-i, --install${reset}         ${rst}$(gettext 'Aplica configurações')"
	echo -e "  ${red}-u, --uninstall${reset}       ${rst}$(gettext 'Remove configurações')"
	echo -e "  ${yellow}-c, --check           ${rst}$(gettext 'Realiza diagnóstico de saúde do sistema')"
	echo -e "  ${green}-b, --backup${reset}          ${rst}$(gettext 'Cria checkpoint dos arquivos críticos')"
	echo -e "  ${red}-r, --rollback${reset}        ${rst}$(gettext 'Reverte os arquivos críticos para o último backup')"
	echo -e "  ${cyan}-h, --help${reset}            ${rst}$(gettext 'Mostra este ajuda')"
}

sh_backup_file() {
	local target="$1"
	local timestamp

	# Se o arquivo não existe, não há o que backupear
	[[ ! -f "$target" ]] && return 0

	timestamp=$(date +%Y%m%d-%H%M%S)
	run_cmd mkdir -p "$bkp_dir"

	# O 'cp -a' garante que permissões e donos originais fiquem intactos
	if cp -a "$target" "${bkp_dir}/$(basename "$target")-${timestamp}.bak"; then
		msg_tab "Backup de segurança criado: ${cyan}$(basename "$target")${rst}"
	else
		warn_tab "Atenção: Falha ao realizar backup de ${target}"
	fi
}

sh_create_checkpoint() {
	local timestamp
	timestamp=$(date +%Y%m%d-%H%M%S)

	msg "Criando ponto de restauração do sistema..."
	run_cmd mkdir -p "$bkp_dir"

	for target in "${aCritic_Files[@]}"; do
		if [[ -f "$target" ]]; then
			if cp -a "$target" "${bkp_dir}/$(basename "$target")-${timestamp}.bak"; then
				msg_tab "Salvaguardado: ${cyan}$(basename "$target")${rst}"
			else
				die "Falha crítica: Não foi possível fazer backup de $target. Abortando por segurança."
			fi
		fi
	done
}

sh_rollback() {
	local bkp_dir="/var/backups/${APP}"

  msg "$(gettext 'Reverte os arquivos críticos para o último backup')"
  msg_tab "$(gettext 'Arquivos'): ${cyan}${aCritic_Files[*]}${rst}"
  if readconf "$(gettext "Restaurar arquivos criticos agora?")"; then
  	msg_tab "$(gettext 'Iniciando processo de rollback para o último estado conhecido...')"

  	for target in "${aCritic_Files[@]}"; do
  		# Encontra o arquivo de backup mais recente para este alvo específico
  		local latest_bkp
  		latest_bkp=$(ls -t "${bkp_dir}/$(basename "$target")"-*.bak 2>/dev/null | head -n 1)

  		if [[ -f "$latest_bkp" ]]; then
  			msg_tab "Restaurando ${cyan}$(basename "$target")${rst} a partir de ${cyan}$(basename "$latest_bkp")${rst}"
  			run_cmd cp -a "$latest_bkp" "$target"
  		else
  			warn_tab "Nenhum backup encontrado para $(basename "$target"). Pulando..."
  		fi
  	done
  	msg "Rollback concluído. ${yellow}Recomendado reiniciar o sistema.${rst}"
  fi
}

check_system_status() {
	local status_count=0
	local total_checks=4 # Swapfile, Sysctl, Serviço THP, Serviço BFQ

	detect_init
  for f in /swapfile "${sysctl_conf}" "${ASERVICES["thp-$init"]}" "${ASERVICES["bfq-$init"]}"; do
    if [[ -f "$f" ]]; then
      ((++status_count))
    else
      ((++errors))
    fi
  done

  #	echo -e "\n${cyan}=== Estado da Otimização ===${rst}"
	if [[ $status_count -eq $total_checks ]]; then
		msg "Status: ${green}OTIMIZADO${rst} (Todos os componentes configurados)"
	elif [[ $status_count -eq 0 ]]; then
		msg "Status: ${red}NÃO OTIMIZADO${rst} (Execute --install)"
	else
		msg "Status: ${yellow}PARCIAL${rst} ($status_count de $total_checks componentes encontrados)"
	fi
}

sh_check_files_critic() {
	msg "$(gettext 'Validação de arquivos críticos de configuração')"
	local files=("/etc/fstab" "/etc/default/grub" "/boot/grub/grub.cfg")
	for f in "${files[@]}"; do
    [[ -f "$f" ]] && msg_tab "Config: ${green}$f ${cyan}encontrado${rst}" || {
			log_err_tab "Config: ${red}$f ausente!${rst}"
			((errors++))
		}
	done
}

sh_check_services() {
	# Validação de Serviços por INIT
	msg "$(gettext 'Verificando serviços via') ${green}${cyan}${init}${rst}"
	case "$init" in
	systemd)
		for svc in preload chili-thp chili-bfq; do
			if systemctl list-unit-files "$svc.service" >/dev/null 2>&1; then
				systemctl is-active --quiet "$svc" && msg_tab "$(gettext 'Serviço') ($svc): ${green}Rodando${rst}" || log_warn_tab "$(gettext 'Serviço') ($svc): ${yellow}Instalado, mas parado${rst}"
			fi
		done
		;;
	runit)
		for svc in preload; do
			if [[ -d "/var/service/$svc" ]]; then
				msg_tab "Serviço ($svc): ${green}Ativo em /var/service/${rst}"
			else
				log_warn_tab "Serviço ($svc): ${yellow}Não encontrado em /var/service/${rst}"
			fi
		done

		for key in "${!ASERVICES[@]}"; do
			service="${ASERVICES[$key]}"
			if [[ "$key" =~ "systemd" ]]; then
				continue
			fi

			if [[ -f "$service" ]]; then
				msg_tab "Config ${green}Ativo em ${service}${rst}"
			else
				log_warn_tab "Config ${yellow}Não encontrado em ${service}${rst}"
			fi
		done
		;;
	esac
}

sh_check_sysctl() {
	# 4. Validação de Sysctl (Comparação direta com o arquivo)
	if [[ -f "${sysctl_conf}" ]]; then
		msg "Sysctl: ${green}Verificando parâmetros no arquivo ${cyan}${sysctl_conf}${rst}"

		for param in "${!ASYSCTL[@]}"; do
			local expected_val="${ASYSCTL[$param]}"
			# Lê o valor que está GRAVADO no arquivo, ignorando comentários e espaços
			local file_val=$(grep "^${param}=" "${sysctl_conf}" | cut -d'=' -f2 | tr -d ' ')

			if [[ -z "$file_val" ]]; then
				log_warn_tab "$param: ${red}Não encontrado no arquivo${rst}"
				((errors++))
			elif [[ "$expected_val" == "$file_val" ]]; then
				msg_tab "$param: ${green}OK ${cyan}($file_val)${rst}"
			else
				log_warn_tab "$param: ${yellow}Divergente (recomendado: $expected_val | Arquivo: $file_val)${rst}"
				((errors++))
			fi
		done
	else
		log_err_tab "Sysctl: ${sysctl_conf} ${red}Arquivo de configuração não encontrado!${rst}"
		((errors++))
	fi
}

sh_health_check() {
	msg "Iniciando diagnóstico profundo do sistema${rst}"
	sh_system_summary

	# 2. Validação do Swapfile
	calculate_swap

	# 3. Validação do Zswap
	sh_check_zswap_lifecycle

	sh_rename_service_on_runit

	# Validação de Sysctl (Comparação direta com o arquivo)
  sh_check_sysctl

	# Validação de Arquivos de Configuração críticos
  sh_check_files_critic

	# Validação de Serviços por INIT
  sh_check_services

	# Chama a nova verificação de estado
	check_system_status
	if [[ $errors -eq 0 ]]; then
    log_ok "${rst}Diagnóstico concluído: ${green}Sistema íntegro.${rst}"
  else
    msg    "${rst}Diagnóstico concluído: ${red}$errors erro(s) encontrado(s).${rst}"
  fi

}

DISTRO="$(detect_distro)"

case "$1" in
"")
	warn "erro: nenhuma operação especificada (use -h para obter ajuda)"
	exit 1
	;;
-s | --show)
	summary
	;;
-ss | --show-extended)
	detect_init
	detect_fs
	detect_ram
	detect_disk
	#calculate_swap
	ensure_debugfs
	summary
	sh_summary_swap
	;;
-i | --install)
	sh_install
	;;
-b | --backup)
	check_root
	sh_create_checkpoint
	;;
-r | --rollback)
	check_root
	sh_rollback
	;;
-c | --check)
	detect_init
	sh_health_check
	;;
-u | --uninstall)
	check_root
	sh_uninstall
	;;
-h | --help)
	usage
	;;
*)
	err "Opção inválida: $1"
	usage
	exit 1
	;;
esac
