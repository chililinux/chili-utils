#!/usr/bin/env bash
# -*- coding: utf-8 -*-
# shellcheck shell=bash disable=SC1091,SC2039,SC2166
#
#  chili-make-md5-iso
#  Created: 2025/02/10 - 11:46
#  Altered: 2026/04/30 - 18:40
