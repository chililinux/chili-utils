export LANGUAGE="${LANGUAGE:-pt_BR}"
export TEXTDOMAINDIR=/usr/share/locale
export TEXTDOMAIN=chili-mount-qemu

#debug
export PS4='${red}${0##*/}${green}[$FUNCNAME]${pink}[$LINENO]${reset}'
#set -x
#set -e
#set -euo pipefail
shopt -s extglob

#system
declare APP="${0##*/}"
declare _VERSION_="0.06.07-20260607"
declare APPDESC="$APP - Wrapper para qemu-nbd"

c0="\033[0m"
c1="\033[0;36m"
c2="\033[1;33m"
c3="\033[1;32m"
c4="\033[1;31m"
c5="\033[1;37m"
cyan="\033[1;36m"

msg() { echo -e "${c1}==>${c0} ${c5}$*${c0}"; }
ok() { echo -e "${c3}==>${c0} $*"; }
warn() { echo -e "${c2}==>${c0} $*"; }
die() {
    echo -e "${c4}$(gettext "Erro:")${c0} $*" >&2
    exit 1
}

IMGDIR="$HOME/.chili-fr/vdisk"

# Seleção inteligente de alvos: arquivo único ou diretório completo
if [[ -n "$2" ]]; then
    if [[ -f "$2" ]]; then
        # Caso seja passado um caminho absoluto/relativo direto válido
        IMGS=( "$2" )
    elif [[ -f "$IMGDIR/$2" ]]; then
        # Caso o arquivo esteja localizado dentro do diretório padrão
        IMGS=( "$IMGDIR/$2" )
    else
        die "$(gettext "O arquivo especificado não foi encontrado localmente nem em") $IMGDIR: $2"
    fi
else
    if [[ ! -d "$IMGDIR" ]]; then
        die "$(gettext "Diretório de imagens não encontrado:") $IMGDIR"
    fi

    mapfile -t IMGS < <(
        find "$IMGDIR" -maxdepth 1 -type f \( -name '*.qcow2' -o -name '*.img' \) | sort
    )
fi

if (( ${#IMGS[@]} == 0 )) && [[ "${1,,}" != "interactive" ]]; then
    warn "$(gettext "Nenhuma imagem (.qcow2 ou .img) foi selecionada ou encontrada.")"
fi

sh_loadmodules() {
    msg "$(gettext "Carregando módulos de kernel (nbd)")"
    sudo modprobe -r nbd 2>/dev/null || true
    sudo modprobe nbd max_part=16
}

sh_connect() {
    if (( ${#IMGS[@]} == 0 )); then
        die "$(gettext "Nenhuma imagem disponível para conectar.")"
    fi

    msg "$(gettext "Conectando imagens")"
    local img dev fmt real_img_path
    local -i timeout
    local -i i=0

    for img in "${IMGS[@]}"; do
        # Resolve o caminho absoluto real da imagem
        real_img_path=$(realpath "$img" 2>/dev/null || echo "$img")

        # Verifica se a imagem já está associada a algum processo qemu-nbd ativo
        if pgrep -a qemu-nbd | grep -F -q "$real_img_path"; then
            local nbd_atual
            nbd_atual=$(pgrep -a qemu-nbd | grep -F "$real_img_path" | grep -o 'connect=/dev/nbd[0-9]*' | cut -d= -f2)
            warn "$(gettext "A imagem") '$(basename "$img")' $(gettext "já está conectada em") ${nbd_atual:-um dispositivo NBD}. $(gettext "Ignorando...")"
            continue
        fi

        # Busca dinamicamente pelo próximo slot NBD totalmente livre/vago
        while [ -r "/sys/block/nbd$i/size" ] && [ "$(cat "/sys/block/nbd$i/size")" -gt 0 ]; do
            ((++i))
        done

        dev="/dev/nbd$i"
        fmt="raw"
        [[ "$img" == *.qcow2 ]] && fmt="qcow2"
        
        msg "$(gettext "Conectando") $(basename "$img") → $dev ($fmt)"
        sudo qemu-nbd -v --fork --connect="$dev" --format="$fmt" "$img"
        
        # Timeout de segurança de 5 segundos para evitar travamento em background
        timeout=0
        until [ -b "$dev" ]; do 
            sleep 0.1
            ((++timeout))
            if (( timeout > 50 )); then
                warn "$(gettext "Falha ao inicializar dispositivo de bloco") $dev $(gettext "no tempo limite.")"
                break
            fi
        done
        
        sudo partprobe "$dev" 2>/dev/null || true
        sudo udevadm settle
        ((++i))
    done

    echo
    msg "$(gettext "Processos qemu-nbd ativos:")"
    pgrep -a qemu-nbd | grep --color=always 'qemu-nbd' || warn "$(gettext "Nenhum processo qemu-nbd em execução.")"
    echo
    msg "$(gettext "Dispositivos de bloco ativos:")"
    lsblk -Ao NAME,PATH,SIZE,TRAN,MODEL,LABEL,SERIAL,PTTYPE | grep --color=always 'nbd' || true
}

sh_disconnect() {
    msg "$(gettext "Desconectando imagens")"
    local i=0
    local img dev
    for img in "${IMGS[@]}"; do
        dev="/dev/nbd$i"
        sudo umount -R "${dev}"* 2>/dev/null || true
        sudo qemu-nbd --disconnect "${dev}" 2>/dev/null || true
        ((++i))
    done

    echo
    msg "$(gettext "Status pós-desconexão:")"
    pgrep -a qemu-nbd | grep --color=always 'qemu-nbd' || ok "$(gettext "Todos os processos qemu-nbd foram encerrados.")"
    echo
    lsblk -Ao NAME,PATH,SIZE,TRAN,MODEL,LABEL,SERIAL,PTTYPE | grep --color=always 'nbd' || true
}

sh_status() {
    msg "$(gettext "Status dos dispositivos")"
    if pgrep -f qemu-nbd >/dev/null; then
        echo -e "${c1}$(gettext "Processos ativos:")${c0}"
        pgrep -a qemu-nbd | grep --color=always 'qemu-nbd'
        echo
        echo -e "${c1}$(gettext "Dispositivos de bloco ativos:")${c0}"
        lsblk -Ao NAME,PATH,SIZE,TRAN,MODEL,LABEL,SERIAL,PTTYPE | grep --color=always 'nbd'
    else
        warn "$(gettext "Nenhum dispositivo/processo nbd ativo conectado.")"
    fi
}

sh_interactive() {
    local escolha opt
    local -a opcoes_menu

    if pgrep -f qemu-nbd >/dev/null; then
        warn "$(gettext "Existem dispositivos NBD ativos no sistema.")"
    fi

    if type -p fzf >/dev/null; then
        escolha=$(
            {
                echo "==> [$(gettext "VER STATUS DETALHADO")]"
                echo "==> [$(gettext "DESCONECTAR TUDO (OFF)")]"
                echo "==> [$(gettext "SAIR")]"
                basename -a "${IMGS[@]}"
            } | fzf --prompt="$(gettext "Escolha uma imagem para conectar ou uma ação: ")" --height=40%
        )

        case "$escolha" in
            "==> [$(gettext "VER STATUS DETALHADO")]")
                sh_status
                ;;
            "==> [$(gettext "DESCONECTAR TUDO (OFF)")]")
                sh_disconnect
                msg "$(gettext "Descarregando módulos")"
                sudo modprobe -r nbd 2>/dev/null || true
                ;;
            "==> [$(gettext "SAIR")]"|"")
                exit 0
                ;;
            *)
                sh_loadmodules
                IMGS=( "$IMGDIR/$escolha" )
                sh_connect
                ;;
        esac
    else
        opcoes_menu=(
            "$(gettext "Ver Status detalhado")"
            "$(gettext "Desconectar tudo (off)")"
            "$(gettext "Sair")"
            "${IMGS[@]}"
        )
        PS3="$(gettext "Escolha uma ação ou imagem para conectar: ")"
        select opt in "${opcoes_menu[@]}"; do
            case "$opt" in
                "$(gettext "Ver Status detalhado")")
                    sh_status
                    break
                    ;;
                "$(gettext "Desconectar tudo (off)")")
                    sh_disconnect
                    msg "$(gettext "Descarregando módulos")"
                    sudo modprobe -r nbd 2>/dev/null || true
                    break
                    ;;
                "$(gettext "Sair")"|"")
                    exit 0
                    ;;
                *)
                    sh_loadmodules
                    IMGS=( "$opt" )
                    sh_connect
                    break
                    ;;
            esac
        done
    fi
}

sh_copia() {
    warn "$(gettext "Atenção: Certifique-se de substituir /dev/sdX pelo destino correto!")"
    sudo dd if=/dev/nbd0 of=/dev/sdX status=progress conv=fsync
}

usage() {
  echo -e "${c1}$(gettext "Uso:")${c0}"
  echo -e "  ${c5}$APP${c0} ${c3}{on|off|status|interactive}${c0} ${c2}[arquivo.qcow2|/caminho/imagem.img]${c0}"
  echo
  echo -e "${c1}$(gettext "Descrição:")${c0}"
  echo -e "  ${c3}on${c0}           $(gettext "conecta imagens (.qcow2 e .img)")"
  echo -e "  ${c3}off${c0}          $(gettext "desconecta todos dispositivos nbd e descarrega o módulo")"
  echo -e "  ${c3}status${c0}       $(gettext "mostra dispositivos e processos conectados")"
  echo -e "  ${c3}interactive${c0}  $(gettext "abre menu interativo (fzf/select) para gerenciamento")"
  echo
  echo -e "${c1}$(gettext "Diretório padrão de busca:")${c0}"
  echo -e "  ${c5}$IMGDIR${c0}"
  echo
  echo -e "${c1}$(gettext "Exemplos:")${c0}"
  echo -e "  ${c2}$APP on${c0}                ${cyan}# $(gettext "Conecta todas imagens do diretório padrão")${c0}"
  echo -e "  ${c2}$APP status${c0}"
  echo -e "  ${c2}$APP off${c0}"
  echo -e "  ${c2}$APP interactive${c0}       ${cyan}# $(gettext "Abre interface de seleção interativa")${c0}"
  echo -e "  ${c2}$APP on vda.qcow2${c0}      ${cyan}# $(gettext "Conecta apenas") \$IMGDIR/vda.qcow2${c0}"
  echo -e "  ${c2}$APP on sda.img${c0}        ${cyan}# $(gettext "Conecta apenas") \$IMGDIR/sda.img${c0}"
  echo -e "  ${c2}$APP on /tmp/file.img${c0}  ${cyan}# $(gettext "Conecta uma imagem fora do diretório padrão")${c0}"
  exit 1
}

case "${1,,}" in
    on)
        sh_loadmodules
        sh_connect
        ;;
    off)
        sh_disconnect
        msg "$(gettext "Descarregando módulos")"
        sudo modprobe -r nbd 2>/dev/null || true
        ;;
    status)
        sh_status
        ;;
    interactive)
        sh_interactive
        ;;
    *)
        usage
        ;;
esac
