msgid "Uso:"
msgstr "使用："

#: usr/local/bin/chili-mount-qemu:267
msgid "Descrição:"
msgstr "描述："

#: usr/local/bin/chili-mount-qemu:268
msgid "conecta imagens (.qcow2 e .img)"
msgstr "連接影像（.qcow2 和 .img）"

#: usr/local/bin/chili-mount-qemu:269
msgid "desconecta todos dispositivos nbd e descarrega o módulo"
msgstr "desconecta todos dispositivos nbd e descarrega o módulo"

#: usr/local/bin/chili-mount-qemu:270
msgid "mostra dispositivos e processos conectados"
msgstr "顯示連接的裝置和進程"

#: usr/local/bin/chili-mount-qemu:271
msgid "abre menu interativo (fzf/select) para gerenciamento"
msgstr "開啟互動式選單（fzf/select）進行管理"

#: usr/local/bin/chili-mount-qemu:273
msgid "Diretório padrão de busca:"
msgstr "預設搜尋目錄："

