msgid "Exemplos:"
msgstr "範例："

#: usr/local/bin/chili-mount-qemu:277
msgid "Conecta todas imagens do diretório padrão"
msgstr "連接預設目錄中的所有圖像"

#: usr/local/bin/chili-mount-qemu:280
msgid "Abre interface de seleção interativa"
msgstr "開啟互動式選擇介面"

#: usr/local/bin/chili-mount-qemu:281 usr/local/bin/chili-mount-qemu:282
msgid "Conecta apenas"
msgstr "僅連接"

#: usr/local/bin/chili-mount-qemu:283
msgid "Conecta uma imagem fora do diretório padrão"
msgstr "連接預設目錄之外的圖像"
