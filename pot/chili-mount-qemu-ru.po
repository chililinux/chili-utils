msgid "Abre interface de seleção interativa"
msgstr "Открывает интерактивный интерфейс выбора"

#: usr/local/bin/chili-mount-qemu:281 usr/local/bin/chili-mount-qemu:282
msgid "Conecta apenas"
msgstr "Только подключение"

#: usr/local/bin/chili-mount-qemu:283
