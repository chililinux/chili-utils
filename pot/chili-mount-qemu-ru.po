msgid "Atenção: Certifique-se de substituir /dev/sdX pelo destino correto!"
msgstr "Внимание: убедитесь, что вы заменили /dev/sdX правильным пунктом назначения!"

#: usr/local/bin/chili-mount-qemu:264
msgid "Uso:"
msgstr "использовать:"

#: usr/local/bin/chili-mount-qemu:267
msgid "Descrição:"
msgstr "Описание:"

#: usr/local/bin/chili-mount-qemu:268
msgid "conecta imagens (.qcow2 e .img)"
msgstr "соединяет изображения (.qcow2 и .img)"

#: usr/local/bin/chili-mount-qemu:269
msgid "desconecta todos dispositivos nbd e descarrega o módulo"
msgstr "отключите все устройства nbd и выгрузите модуль"

